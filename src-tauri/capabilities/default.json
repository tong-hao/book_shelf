{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-open",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-path"
  ]
}
